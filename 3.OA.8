<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Abi's Two-Step Treasure Quest</title>
    <style>
        body { 
            font-family: 'Comic Sans MS', Arial, sans-serif; 
            padding: 20px; 
            background-color: #f0f8ff; 
            text-align: center; 
            touch-action: manipulation;
        }
        h1 { color: #ff4500; font-size: 36px; margin-bottom: 5px; }
        h2 { color: #1e90ff; margin-top: 0; }
        
        .card { 
            background-color: white; 
            padding: 30px; 
            border-radius: 15px; 
            margin: 20px auto; 
            max-width: 700px; 
            box-shadow: 0 8px 16px rgba(0,0,0,0.15); 
        }
        
        #problemDisplay {
            font-size: 28px;
            color: #333;
            line-height: 1.5;
            margin: 20px 0;
            padding: 15px;
            background-color: #fff9c4;
            border-radius: 10px;
            border: 2px dashed #fbc02d;
        }

        #answerBox {
            font-size: 40px;
            color: #4b0082;
            font-weight: bold;
            min-height: 50px;
            margin: 20px auto;
            width: 200px;
            border-bottom: 4px solid #1e90ff;
        }

        /* iPad Friendly Number Pad */
        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            max-width: 350px;
            margin: 0 auto;
        }

        .num-btn {
            background-color: #1e90ff;
            color: white;
            font-size: 32px;
            padding: 20px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 4px 0 #0d47a1;
        }

        .num-btn:active {
            transform: translateY(4px);
            box-shadow: none;
        }

        .action-btn {
            background-color: #32cd32;
            box-shadow: 0 4px 0 #1b5e20;
        }

        .clear-btn {
            background-color: #ff5252;
            box-shadow: 0 4px 0 #b71c1c;
        }

        /* Hint System */
        #hintBtn {
            background-color: #ffa500;
            color: white;
            font-size: 20px;
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 4px 0 #e65100;
            margin-top: 20px;
            display: none; /* Hidden by default! */
        }
        
        #hintDisplay {
            font-size: 22px;
            color: #e65100;
            margin-top: 15px;
            font-weight: bold;
            display: none;
        }

        #feedback { 
            font-size: 28px; 
            font-weight: bold; 
            margin-top: 20px; 
            min-height: 40px; 
        }

        #nextBtn {
            background-color: #9c27b0;
            color: white;
            font-size: 24px;
            padding: 15px 40px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            box-shadow: 0 4px 0 #4a148c;
            margin-top: 20px;
            display: none;
        }

        .progress {
            font-size: 20px;
            color: #555;
            font-weight: bold;
            margin-top: 20px;
        }
        
        #startScreen, #endScreen { display: none; }
    </style>
</head>
<body>

    <div id="startScreen" class="card" style="display: block;">
        <h1>👑 Abi's Two-Step Treasure Quest 👑</h1>
        <h2>Can you solve the puzzles to open the chests?</h2>
        <button class="num-btn action-btn" style="width: 100%; margin-top: 30px;" onclick="startGame()">Start Quest!</button>
    </div>

    <div id="gameArea" class="card" style="display: none;">
        <h2>Treasure Chest <span id="currentChestNum">1</span></h2>
        
        <div id="problemDisplay">Loading problem...</div>
        
        <div id="answerBox"></div>

        <div id="numpadArea">
            <div class="numpad">
                <button class="num-btn" onclick="addNumber(1)">1</button>
                <button class="num-btn" onclick="addNumber(2)">2</button>
                <button class="num-btn" onclick="addNumber(3)">3</button>
                <button class="num-btn" onclick="addNumber(4)">4</button>
                <button class="num-btn" onclick="addNumber(5)">5</button>
                <button class="num-btn" onclick="addNumber(6)">6</button>
                <button class="num-btn" onclick="addNumber(7)">7</button>
                <button class="num-btn" onclick="addNumber(8)">8</button>
                <button class="num-btn" onclick="addNumber(9)">9</button>
                <button class="num-btn clear-btn" onclick="clearAnswer()">C</button>
                <button class="num-btn" onclick="addNumber(0)">0</button>
                <button class="num-btn action-btn" onclick="checkAnswer()">GO</button>
            </div>
        </div>

        <button id="hintBtn" onclick="showHint()">💡 Need a Hint?</button>
        <div id="hintDisplay"></div>

        <div id="feedback"></div>
        <button id="nextBtn" onclick="nextProblem()">Next Chest ➡️</button>

        <div class="progress">Chests Unlocked: <span id="score">0</span> / <span id="totalQuestions"></span></div>
    </div>

    <div id="endScreen" class="card">
        <h1>🏆 Quest Complete! 🏆</h1>
        <h2>You are a Two-Step Math Master!</h2>
        <h1 style="font-size: 80px; margin: 20px;">💎💰👑</h1>
        <button class="num-btn action-btn" style="width: 100%;" onclick="location.reload()">Play Again</button>
    </div>

    <script>
        // 👇 ADD OR EDIT PROBLEMS HERE 👇
        const problems = [
            {
                text: "Abi bakes 4 trays of cookies. Each tray has 5 cookies. She gives 8 cookies to her friends. How many cookies does she have left?",
                hint: "Step 1: Multiply to find out how many cookies she baked in total (4 x 5). \nStep 2: Subtract the 8 cookies she gave away.",
                answer: 12
            },
            {
                text: "Abi has 20 stickers. She buys 10 more stickers at the store. She wants to put an equal amount of stickers onto 5 pages. How many stickers go on each page?",
                hint: "Step 1: Add to find her total number of stickers. \nStep 2: Divide that total equally into 5 pages.",
                answer: 6
            },
            {
                text: "There are 3 boxes of crayons. Each box has 8 crayons. Abi loses 4 crayons. How many crayons are left?",
                hint: "Step 1: Multiply to find the total crayons in the boxes. \nStep 2: Subtract the 4 that got lost.",
                answer: 20
            },
            {
                text: "Abi reads 15 pages of her book on Saturday and 12 pages on Sunday. Her book is 50 pages long. How many pages does she have left to read?",
                hint: "Step 1: Add the pages from Saturday and Sunday together. \nStep 2: Subtract that number from the 50 total pages.",
                answer: 23
            },
            {
                text: "Abi buys 3 packs of trading cards. Each pack costs $4. She pays with a $20 bill. How much change does she get back?",
                hint: "Step 1: Multiply to find out how much the cards cost altogether. \nStep 2: Subtract that cost from the $20 bill.",
                answer: 8
            }
        ];

        let currentIndex = 0;
        let currentAnswer = "";
        let attemptsThisProblem = 0;
        let audioCtx;

        document.getElementById('totalQuestions').innerText = problems.length;

        function startGame() {
            // Initialize audio context for iPad
            window.AudioContext = window.AudioContext || window.webkitAudioContext;
            audioCtx = new AudioContext();
            if (audioCtx.state === 'suspended') audioCtx.resume();

            document.getElementById('startScreen').style.display = 'none';
            document.getElementById('gameArea').style.display = 'block';
            loadProblem();
        }

        function loadProblem() {
            currentAnswer = "";
            attemptsThisProblem = 0;
            document.getElementById('answerBox').innerText = "";
            document.getElementById('feedback').innerText = "";
            document.getElementById('hintBtn').style.display = 'none';
            document.getElementById('hintDisplay').style.display = 'none';
            document.getElementById('nextBtn').style.display = 'none';
            document.getElementById('numpadArea').style.pointerEvents = 'auto';
            document.getElementById('numpadArea').style.opacity = '1';

            document.getElementById('currentChestNum').innerText = currentIndex + 1;
            document.getElementById('problemDisplay').innerText = problems[currentIndex].text;
            document.getElementById('hintDisplay').innerText = problems[currentIndex].hint;
        }

        function addNumber(num) {
            if (currentAnswer.length < 4) {
                currentAnswer += num;
                document.getElementById('answerBox').innerText = currentAnswer;
            }
        }

        function clearAnswer() {
            currentAnswer = "";
            document.getElementById('answerBox').innerText = currentAnswer;
        }

        function checkAnswer() {
            if (currentAnswer === "") return;

            let guess = parseInt(currentAnswer);
            let correct = problems[currentIndex].answer;
            let feedbackEl = document.getElementById('feedback');

            if (guess === correct) {
                playDing();
                feedbackEl.innerText = "✅ You cracked the code!";
                feedbackEl.style.color = "#32cd32";
                
                document.getElementById('numpadArea').style.pointerEvents = 'none';
                document.getElementById('numpadArea').style.opacity = '0.5';
                document.getElementById('hintBtn').style.display = 'none';
                document.getElementById('hintDisplay').style.display = 'none';
                document.getElementById('nextBtn').style.display = 'inline-block';
                document.getElementById('score').innerText = currentIndex + 1;
            } else {
                playWrongBuzz();
                attemptsThisProblem++;
                feedbackEl.innerText = "❌ Not quite! Try again.";
                feedbackEl.style.color = "#f44336";
                clearAnswer();

                // Show the hint button ONLY after they miss it once
                if (attemptsThisProblem >= 1) {
                    document.getElementById('hintBtn').style.display = 'inline-block';
                }
            }
        }

        function showHint() {
            document.getElementById('hintBtn').style.display = 'none';
            document.getElementById('hintDisplay').style.display = 'block';
        }

        function nextProblem() {
            currentIndex++;
            if (currentIndex >= problems.length) {
                document.getElementById('gameArea').style.display = 'none';
                document.getElementById('endScreen').style.display = 'block';
                playVictoryFanfare();
            } else {
                loadProblem();
            }
        }

        // --- Audio Synthesizer Logic ---
        function playTone(type, freq, dur) {
            if (!audioCtx) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            let osc = audioCtx.createOscillator();
            let gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            gain.gain.setValueAtTime(0.5, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + dur);
            osc.start();
            osc.stop(audioCtx.currentTime + dur);
        }

        function playDing() { playTone('sine', 1000, 0.3); }
        function playWrongBuzz() { playTone('sawtooth', 150, 0.2); }
        
        function playVictoryFanfare() {
            if (!audioCtx) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const chords = [
                { frequencies: [261.63, 329.63, 392.00], duration: 0.4, startTime: 0 },
                { frequencies: [349.23, 440.00, 523.25], duration: 0.4, startTime: 0.4 },
                { frequencies: [392.00, 493.88, 587.33], duration: 0.4, startTime: 0.8 },
                { frequencies: [261.63, 329.63, 392.00, 523.25], duration: 1.5, startTime: 1.2 }
            ];
            chords.forEach(chord => {
                chord.frequencies.forEach(freq => {
                    let osc = audioCtx.createOscillator();
                    let gain = audioCtx.createGain();
                    osc.type = 'triangle';
                    osc.frequency.value = freq;
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    gain.gain.setValueAtTime(0, audioCtx.currentTime + chord.startTime);
                    gain.gain.linearRampToValueAtTime(0.2, audioCtx.currentTime + chord.startTime + 0.05);
                    gain.gain.setValueAtTime(0.2, audioCtx.currentTime + chord.startTime + chord.duration - 0.1);
                    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + chord.startTime + chord.duration);
                    osc.start(audioCtx.currentTime + chord.startTime);
                    osc.stop(audioCtx.currentTime + chord.startTime + chord.duration);
                });
            });
        }
    </script>
</body>
</html>
